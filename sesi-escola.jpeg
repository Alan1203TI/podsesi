:root{--blue:#06499b;--blue2:#02336f;--dark:#03101f;--card:#061a31;--yellow:#ffd21a;--text:#f6fbff;--muted:#b9c7d8;--line:rgba(255,255,255,.12)}*{box-sizing:border-box}body{margin:0;font-family:Arial,Helvetica,sans-serif;background:radial-gradient(circle at top,#0b5ab7 0,#061a31 42%,#020912 100%);color:var(--text);min-height:100vh}.app-shell{display:grid;grid-template-columns:250px 1fr;min-height:calc(100vh - 110px);padding-bottom:110px}.sidebar{background:rgba(2,9,18,.72);border-right:1px solid var(--line);padding:24px;position:sticky;top:0;height:100vh}.brand{display:flex;gap:12px;align-items:center}.brand strong{font-size:24px}.brand small{display:block;color:var(--muted);margin-top:4px}.logo-dot{display:grid;place-items:center;width:44px;height:44px;border-radius:14px;background:var(--yellow);color:#03101f;font-weight:bold}nav{display:grid;gap:10px;margin-top:34px}.nav-btn,.admin-link,.ghost,.primary,.play-card,.circle{border:0;border-radius:999px;padding:13px 16px;font-weight:700;cursor:pointer;text-decoration:none}.nav-btn{background:transparent;color:var(--muted);text-align:left}.nav-btn.active,.nav-btn:hover{background:rgba(255,255,255,.1);color:white}.admin-link{display:block;margin-top:30px;background:#0d2a4d;color:white;text-align:center}.content{padding:28px;overflow:hidden}.hero{position:relative;border-radius:32px;overflow:hidden;min-height:340px;background:#063970;margin-bottom:24px}.hero-bg{position:absolute;inset:0;background:linear-gradient(90deg,rgba(3,16,31,.95),rgba(3,16,31,.55)),url('assets/sesi-escola.jpeg') center/cover;filter:saturate(1.1)}.hero-content{position:relative;display:flex;gap:28px;align-items:center;padding:38px}.hero-cover{width:220px;max-height:300px;object-fit:cover;border-radius:22px;box-shadow:0 18px 50px rgba(0,0,0,.45)}.eyebrow{color:var(--yellow);font-weight:800;letter-spacing:.08em;text-transform:uppercase}.hero h1{font-size:64px;margin:10px 0}.hero p{font-size:20px;color:#d8e7f8;max-width:680px}.hero-actions{display:flex;gap:12px;flex-wrap:wrap}.primary{background:var(--yellow);color:#03101f}.ghost{background:rgba(255,255,255,.12);color:white}.toolbar{display:flex;gap:12px;margin:22px 0}.toolbar input,.toolbar select,.admin-card input,.admin-card textarea,.admin-card select{width:100%;background:rgba(255,255,255,.08);border:1px solid var(--line);border-radius:18px;color:white;padding:15px;font-size:16px}.toolbar select{max-width:210px}.section-title{display:flex;justify-content:space-between;align-items:center}.section-title h2{font-size:30px}.section-title span{color:var(--muted)}.episodes-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:18px}.episode{background:rgba(255,255,255,.08);border:1px solid var(--line);border-radius:24px;overflow:hidden;cursor:pointer;transition:.2s}.episode:hover{transform:translateY(-4px);background:rgba(255,255,255,.12)}.episode img{width:100%;height:190px;object-fit:cover;background:#0a203d}.episode-info{padding:16px}.episode-info span{color:var(--yellow);font-weight:bold;font-size:13px}.episode-info h3{margin:8px 0;font-size:20px}.episode-info p{color:var(--muted);min-height:44px}.play-card{background:#fff;color:#03101f}.player-bar{position:fixed;left:0;right:0;bottom:0;height:110px;background:rgba(2,9,18,.96);border-top:1px solid var(--line);display:flex;align-items:center;gap:14px;padding:14px 22px;z-index:10}.player-bar img{width:74px;height:74px;border-radius:14px;object-fit:cover}.now-playing{min-width:210px;max-width:340px}.now-playing small{display:block;color:var(--muted);margin-top:5px}.circle{width:46px;height:46px;border-radius:50%;padding:0;background:rgba(255,255,255,.12);color:white}.circle.big{background:var(--yellow);color:#03101f;width:58px;height:58px}audio{flex:1;min-width:160px}.admin-page{display:grid;place-items:center;padding:26px}.admin-card{width:min(760px,100%);background:rgba(2,9,18,.86);border:1px solid var(--line);border-radius:28px;padding:28px}.admin-brand{margin-bottom:20px}.admin-card label{display:block;margin:14px 0;color:var(--muted);font-weight:bold}.admin-card textarea{height:100px}.full{width:100%;margin-top:10px}.hint{font-size:13px;color:var(--muted);background:rgba(255,255,255,.08);padding:12px;border-radius:14px}#generatedCode{height:150px;color:#fff}.back{background:transparent;border:1px solid var(--line)}.empty{padding:30px;color:var(--muted)}@media(max-width:860px){.app-shell{display:block}.sidebar{position:relative;height:auto;padding:16px}.sidebar nav{display:flex;overflow:auto;margin-top:18px}.nav-btn{white-space:nowrap}.content{padding:16px}.hero-content{display:block;padding:22px}.hero-cover{width:150px;height:150px}.hero h1{font-size:42px}.toolbar{display:block}.toolbar select{max-width:none;margin-top:10px}.player-bar{height:auto;flex-wrap:wrap}.now-playing{flex:1}.player-bar audio{width:100%;flex-basis:100%}}
